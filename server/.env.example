PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=traveloop
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
AUTO_SYNC=false

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# cookie security
COOKIE_SECURE=false

# uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@traveloop.local
