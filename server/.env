PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=traveloop
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
AUTO_SYNC=true

# JWT
JWT_ACCESS_SECRET=travel_loop_secret_key_2024
JWT_REFRESH_SECRET=travel_loop_refresh_key_2024
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# cookie security
COOKIE_SECURE=false

# uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
